# ── LinkedIn scraping (opt-in — requires Chrome + chromedriver) ─
LINKEDIN_ENABLED=true

# ── Google Sheets output ─────────────────────────────────────
# 1. Create a Google Sheet in your Drive (any name).
# 2. Share it with your service account email (from credentials.json).
# 3. Download the JSON key → save as credentials.json in project root.
GOOGLE_SHEET_NAME=Job Search Pipeline
GOOGLE_CREDENTIALS_PATH=credentials.json

# ── Email digest (Gmail) ─────────────────────────────────────
# EMAIL_PASSWORD must be a Gmail App Password, NOT your login password.
# Generate one at: https://myaccount.google.com/apppasswords
EMAIL_SENDER=your.gmail@gmail.com
EMAIL_RECIPIENT=your.gmail@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# ── Slack alert ──────────────────────────────────────────────
# Create a webhook at: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK=https://hooks.slack.com/services/XXX/YYY/ZZZ

# ── OpenAI (optional — enables AI job parsing & skill extraction) ─
# Leave commented out to skip AI parsing; the pipeline still runs fine.
# OPENAI_API_KEY=sk-...
