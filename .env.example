# ============================================================
#  Job Search Pipeline — Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to git (it's already in .gitignore).
# ============================================================

# ── Job search parameters ────────────────────────────────────
# TARGET_ROLE=Repo → Settings → Secrets and variables → Actions → Repository secret
# TARGET_LOCATION=Repo → Settings → Secrets and variables → Actions → Repository secret

# ── Greenhouse companies (public API — no auth needed) ───────
# Comma-separated list of company slugs on greenhouse.io
# Example: stripe,airbnb,shopify,hubspot,discord
# GREENHOUSE_COMPANIES=Repo → Settings → Secrets and variables → Actions → Repository secret

# ── Lever companies (public API — no auth needed) ────────────
# Comma-separated Lever ATS slugs. Find yours at:
#   https://jobs.lever.co/<company-slug>
# Working examples: jumpcloud, plaid
# NOTE: Many large companies have migrated away from Lever.
#       Test a slug at: https://api.lever.co/v0/postings/<slug>?mode=json
# LEVER_COMPANIES=Repo → Settings → Secrets and variables → Actions → Repository secret

# ── LinkedIn scraping (opt-in, requires Chrome + chromedriver) ─
# Set to "true" ONLY if you have Chrome + chromedriver installed.
LINKEDIN_ENABLED=false

# ── Google Sheets output ─────────────────────────────────────
# 1. Create a Google Sheet in your Drive (any name works).
# 2. Share it with the service account email in credentials.json.
# 3. Download a fresh JSON key for that service account and save
#    it as credentials.json in this project folder.
# 4. Set GOOGLE_SHEET_NAME to exactly match your sheet's title.
# GOOGLE_SHEET_NAME=Repo → Settings → Secrets and variables → Actions → Repository secret
GOOGLE_CREDENTIALS_PATH=credentials.json

# ── Email digest (Gmail) ─────────────────────────────────────
# EMAIL_PASSWORD must be a Gmail App Password, NOT your login password.
# Generate one at: https://myaccount.google.com/apppasswords
# (Google Account → Security → 2-Step Verification → App passwords)
# EMAIL_SENDER=your.gmail@gmail.com
# EMAIL_RECIPIENT=your.gmail@gmail.com
# EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# ── Slack alert ──────────────────────────────────────────────
# Create a Slack app at https://api.slack.com/apps
# Enable "Incoming Webhooks" and copy the webhook URL here.
# SLACK_WEBHOOK=https://hooks.slack.com/services/XXX/YYY/ZZZ

# ── OpenAI (optional — enables AI job parsing & skill extraction) ─
# Leave blank to skip AI parsing; the pipeline still runs without it.
# OPENAI_API_KEY=sk-...
